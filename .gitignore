# Large genomic data — regenerable or re-downloadable, don't commit
*.fa
*.fasta
*.fna
*.fai
*.gz
*.bam
*.bigWig

# But DO keep small BED files (coordinates are tiny + useful to version)
!*.bed

# Model cache / weights
*.bin
*.safetensors
__pycache__/
*.pyc

# Regenerable interval caches (rebuilt automatically from the .gtf.gz files)
*.pkl

# Local virtualenv (created to isolate DNABERT-2's fragile trust_remote_code
# deps from the shared transformers install)
venv_genomewide/

# OS junk
.DS_Store

# Optional: backups you made
*_REAL_backup.*